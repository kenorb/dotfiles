# Lychee config to exclude links
# @docs: <https://lychee.cli.rs/recipes/excluding-links/>
# Keep the order sorted.

^https?://127\.0\.0\.1
^https?://example\.com
^https?://localhost

# Placeholders and templates
^https://github\.com/org/repo

# Links to ignore.
^https://dl\.deno\.land/release/
^https://github\.com/zyedidia/eget/releases/download/v
^https://mega\.nz/linux/repo/xUbuntu_
